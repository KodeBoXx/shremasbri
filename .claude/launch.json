{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--listen", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "Static Site V2 (npx serve /v2)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "v2", "--listen", "3001", "--no-clipboard"],
      "port": 3001
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    }
  ]
}
